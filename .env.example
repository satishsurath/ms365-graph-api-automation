# Microsoft Entra app registration
# Use "organizations" for the recommended org-only app,
# "common" for a consumer-compatible app, or a tenant GUID/domain to lock to one tenant.
MSFT_TENANT_ID=organizations
MSFT_CLIENT_ID=
MSFT_AUTHORITY=https://login.microsoftonline.com/organizations
MSFT_REDIRECT_URI=http://localhost

# OpenID Connect helper scopes.
# Important: MSAL commonly adds openid/profile/offline_access/email for you.
# Keep these separate from Graph scopes so scripts can decide whether to pass them explicitly.
MSFT_OIDC_SCOPES=openid profile offline_access

# Core delegated Graph scopes for broad user-content automation.
MSFT_GRAPH_SCOPES=User.Read Mail.ReadWrite Mail.Send MailboxSettings.ReadWrite Calendars.ReadWrite Contacts.ReadWrite Files.ReadWrite Files.ReadWrite.All Sites.ReadWrite.All Notes.ReadWrite Tasks.ReadWrite People.Read

# Shared-resource extensions for delegated user access to shared content.
# These are most useful in work or school tenants.
MSFT_GRAPH_SCOPES_SHARED=Mail.ReadWrite.Shared Mail.Send.Shared Calendars.ReadWrite.Shared Contacts.ReadWrite.Shared Tasks.ReadWrite.Shared Notes.ReadWrite.All

# Collaboration and org-focused extensions.
# These are primarily useful for work or school accounts and may require admin consent or licensing.
MSFT_GRAPH_SCOPES_COLLAB=OnlineMeetings.ReadWrite Presence.ReadWrite Chat.Create Chat.ReadWrite ChatMessage.Send Channel.ReadBasic.All ChannelMessage.Send ChannelMessage.ReadWrite Team.ReadBasic.All Group.ReadWrite.All

# Local token cache location for future helper scripts.
MSFT_TOKEN_CACHE_PATH=.tokens/msal_cache.json

# Session log directory for Graph-backed script runs.
MSFT_SESSION_LOG_DIR=.session_logs

# When true, session logs include verbose payload and identity details.
# Keep this false for normal use. Access tokens are never logged.
MSFT_SESSION_LOG_DEBUG=false

# Local encrypted Graph artifact store.
# The SQLite index and encrypted artifact files live under this directory.
MSFT_GRAPH_STORE_DIR=.graph_store

# OS keyring service name used to store the graph store master key.
MSFT_GRAPH_STORE_KEYRING_SERVICE=ms365-graph-api-automation
